# Chat backend (Groq proxy).
# - In production on Cloudflare Workers: leave empty. Frontend uses /api/chat
#   on same origin (served by worker/index.ts → worker/chat.ts).
# - In local dev: point to apps/chat-api/ FastAPI server, e.g.
#   http://localhost:8000
NEXT_PUBLIC_CHAT_API_URL=

# Groq API key (server-side only — used by worker/chat.ts on Cloudflare
# Workers and by apps/chat-api/main.py in local dev).
# NEVER expose to the browser. Set as a Worker secret in the Cloudflare
# dashboard: Worker → Settings → Variables and Secrets.
GROQ_API_KEY=

# Comma-separated list of allowed origins for the chat handler CORS.
# Used by worker/chat.ts — the allowlist is strict, no regex fallback.
ALLOWED_ORIGINS=https://vexorterminal.com,https://www.vexorterminal.com

# Vexor contracts on Base Sepolia (chainId 84532)
NEXT_PUBLIC_VEXOR_TOKEN_TESTNET=0x200b75db62fa66f325191b34ef784ade26321570
NEXT_PUBLIC_VEXOR_STAKING_TESTNET=0x6a345b8390a67681764521d146853211dd089062
NEXT_PUBLIC_VEXOR_GOVERNANCE_TESTNET=0xd1850b4c2e663b45a49330d00637db78197be31c
