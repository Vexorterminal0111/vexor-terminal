# Chat backend (Groq proxy).
# - In production on Cloudflare Pages: leave empty. Frontend uses /api/chat
#   on same origin (served by functions/api/chat.ts).
# - In local dev: point to apps/chat-api/ FastAPI server, e.g.
#   http://localhost:8000
NEXT_PUBLIC_CHAT_API_URL=

# Groq API key (server-side only — used by functions/api/chat.ts on
# Cloudflare Pages and by apps/chat-api/main.py in local dev).
# NEVER expose to the browser. Set in Cloudflare Pages dashboard as a
# (non-public) environment variable on the Production environment.
GROQ_API_KEY=

# Comma-separated list of allowed origins for the chat function CORS.
# Used by functions/api/chat.ts. Cloudflare *.pages.dev subdomains are
# always allowed by regex; only list your custom domains here.
ALLOWED_ORIGINS=https://vexorterminal.com,https://www.vexorterminal.com

# Vexor contracts on Base Sepolia (chainId 84532)
NEXT_PUBLIC_VEXOR_TOKEN_TESTNET=0x200b75db62fa66f325191b34ef784ade26321570
NEXT_PUBLIC_VEXOR_STAKING_TESTNET=0x6a345b8390a67681764521d146853211dd089062
NEXT_PUBLIC_VEXOR_GOVERNANCE_TESTNET=0xd1850b4c2e663b45a49330d00637db78197be31c
